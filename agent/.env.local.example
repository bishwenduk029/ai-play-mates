# Copy to .env.local and fill in. Same values as the Next.js app's .env.local
# (LiveKit creds) plus the Google API key for the Gemini realtime model.

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

GOOGLE_API_KEY=your_google_api_key
SPAC_APP_URL=http://localhost:3000
