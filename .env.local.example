SPAC_APP_URL=http://localhost:3000

# Better Auth
BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost:3000

# Turso (libSQL database) — https://turso.tech
# Create a DB: turso db create ai-play-mates
# Get URL: turso db show ai-play-mates --url
# Get token: turso db tokens create ai-play-mates
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_auth_token

# SPAC_APP_URL — the base URL of the Next.js app (for agent to fetch manifests)
# Dev: http://localhost:3000  Prod: https://your-app.vercel.app
SPAC_APP_URL=http://localhost:3000

# Dodo Payments (subscriptions) — https://dodopayments.com
# Get keys from dashboard: https://dashboard.dodopayments.com
DODO_PAYMENTS_API_KEY=your_api_key
DODO_PAYMENTS_WEBHOOK_KEY=your_webhook_secret
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_PRODUCT_ID=your_subscription_product_id
DODO_PAYMENTS_RETURN_URL=https://ai-play-zone.vercel.app/play
